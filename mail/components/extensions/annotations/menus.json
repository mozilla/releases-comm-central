              }
            ]
          },
          "srcUrl": {
            "annotations": [
              {
                "note": "Host permission is required."
              }
            ]
          },
          "pageUrl": {
            "annotations": [
              {
                "note": "Host permission is required."
              }
            ]
          },
          "frameUrl": {
            "annotations": [
              {
                "note": "Host permission is required."
              }
            ]
          },
          "selectionText": {
            "annotations": [
              {
                "note": "Host permission is required."
              }
            ]
          }
        }
      },
      {
        "id": "OnClickData",
        "properties": {
          "fieldId": {
            "enums": {
              "composeSubject": {
                "annotations": [
                  {
                    "text": "The subject field of the message compose window."
                  }
                ]
              },
              "composeTo": {
                "annotations": [
                  {
                    "text": "The To field of the message compose window."
                  }
                ]
              },
              "composeCc": {
                "annotations": [
                  {
                    "text": "The Cc field of the message compose window."
                  }
                ]
              },
              "composeBcc": {
                "annotations": [
                  {
                    "text": "The Bcc field of the message compose window."
                  }
                ]
              },
              "composeReplyTo": {
                "annotations": [
                  {
                    "text": "The Reply-To field of the message compose window."
                  }
                ]
              },
              "composeNewsgroupTo": {
                "annotations": [
                  {
                    "text": "The Newsgroup field of the message compose window."
                  }
                ]
              }
            }
          }
        }
      },
      {
        "id": "MenuActionCommand",
        "enums": {
          "_execute_browser_action": {
            "annotations": [
              {
                "text": "Triggers the browser action of the extension."
              }
            ]
          },
          "_execute_action": {
            "annotations": [
              {
                "text": "Triggers the action of the extension."
              }
            ]
          },
          "_execute_compose_action": {
            "annotations": [
              {
                "text": "Triggers the compose action of the extension."
              }
            ]
          },
          "_execute_message_display_action": {
            "annotations": [
              {
                "text": "Triggers the message display action of the extension."
              }
            ]
          }
        }
      },
      {
        "id": "MenuIconDictionary",
        "annotations": [
          {
            "text": "Example:"
          },
          {
            "code": "includes/IconPath.json"
          },
          {
            "text": "See the $(url:mdn-icon-size)[MDN documentation about choosing icon sizes] for more information on this topic."
          }
        ]
      }
    ],
    "functions": [
      {
        "name": "create",
        "type": "function",
        "parameters": [
          {
            "type": "object",
            "name": "createProperties",
            "properties": {
              "command": {
                "choices": [
                  {
                    "type": "string"
                  },
                  {
                    "$ref": "menus.MenuActionCommand",
                    "annotations": [
                      {
                        "version_added": "66",
                        "description": "This is an enum which was added in Thunderbird 124 to explicitly spell out built-in commands, but as they are just strings they have been supported since Thunderbird 66."
                      }
                    ]
                  }
                ]
              }
            }
          }
        ]
      }
    ]
  }
]
