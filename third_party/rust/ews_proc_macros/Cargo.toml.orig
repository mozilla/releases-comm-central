[package]
name = "ews_proc_macros"
version = "0.1.0"
edition = "2021"
description = "Procedural macros for the ews crate."
categories = ["data-structures"]
keywords = ["exchange", "ews"]
readme = "../README.md"
license = "MPL-2.0"
repository = "https://github.com/thunderbird/ews-rs"
exclude = [".github", ".vscode"]

[lib]
proc-macro = true

[dependencies]
syn = { version = "2.0", features = ["full"] }
quote = "1.0"
